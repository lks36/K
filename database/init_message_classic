CREATE TABLE message_classic (
    id_message INTEGER PRIMARY KEY AUTOINCREMENT,
    id_partie INTEGER,
    id_player INTEGER,
    creation TIMESTAMP,
    FOREIGN KEY (id_player) REFERENCES users(id),
    FOREIGN KEY (id_partie) REFERENCES classic(id),
    FOREIGN KEY (id_partie) REFERENCES tournoi(id),
    FOREIGN KEY (id_partie) REFERENCES classic_perso(id)

);